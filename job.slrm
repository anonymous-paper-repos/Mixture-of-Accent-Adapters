#SBATCH -p gpu-v100-32g

#SBATCH --job-name="moaa_dhf"
#SBATCH --output=%x.out

#SBATCH --mem=64G
#SBATCH --time=120:00:00
#SBATCH --gres=gpu:v100:1
#SBATCH --cpus-per-task=8
#SBATCH --export=HOME,USER,TERM,WRKDIR

module load mamba
module load triton/2025.1-gcc
module load cuda/12.6.2

source activate /path/to/conda_env

AESRC_TRAIN_DIR="/path/to/aesrc/train_shards"
LIBRISPEECH_DIR="/path/to/librispeech/train-clean-100"

AESRC_TEST_DIR="/path/to/aesrc/test"
OPENSLR_TEST_DIR="/path/to/openslr/test"
EDACC_TEST_DIR="/path/to/edacc/test"
GLOBE_TEST_DIR="/path/to/globe/test"

OUT_ROOT="runs"
RUN_NAME="moaa_$(date +%Y%m%d_%H%M%S)"
RUN_DIR="${OUT_ROOT}/${RUN_NAME}"

# ---------------------------
# 1) Run MoAA
# ---------------------------
python -u moaa.py \
  --aesrc_train_dir "${AESRC_TRAIN_DIR}" \
  --librispeech_dir "${LIBRISPEECH_DIR}" \
  --aesrc_test_dir "${AESRC_TEST_DIR}" \
  --openslr_test_dir "${OPENSLR_TEST_DIR}" \
  --edacc_test_dir "${EDACC_TEST_DIR}" \
  --globe_test_dir "${GLOBE_TEST_DIR}" \
  --output_root "${OUT_ROOT}" \
  --run_name "${RUN_NAME}" \
  --model_name "openai/whisper-small" \
  --language "en" \
  --task "transcribe" \
  --seed 42 \
  --batch_size 16 \
  --epochs 10 \
  --lr 5e-4 \
  --num_adapters 10 \
  --bottleneck_size 192 \
  --num_accents 10 \
  --accent_ignore_index -100 \
  --eval_split_ratio 0.1 \
  --grl_lambda 1.0

# ---------------------------
# 2) Run DHF (reference-free)
# ---------------------------
DHF_CSV="${RUN_DIR}/csv/internal_test_multitask.csv"
DHF_OUT_DIR="${RUN_DIR}/dhf_ref_free_$(date +%Y%m%d_%H%M%S)"

python -u dhf.py \
  --csv_path "${DHF_CSV}" \
  --pred_col pred_text \
  --out_dir "${DHF_OUT_DIR}" \
  --no_insertion_analysis \
  --no_eval \
  --filter_numeric_only \
  --margin 1.0

echo "DONE: MoAA run dir: ${RUN_DIR}"
echo "DONE: DHF outputs : ${DHF_OUT_DIR}"

